@model GymFlow.Models.Exercise
@using GymFlow.Models

@{
    ViewData["Title"] = "Edytuj ćwiczenie";
}

<div class="container mt-4">

    <h1 class="mb-4">Edytuj ćwiczenie</h1>

    <form asp-action="Edit" method="post">

        <!-- ID (hidden) -->
        <input type="hidden" asp-for="Id" />

        <!-- Nazwa -->
        <div class="mb-3">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <!-- Opis -->
        <div class="mb-3">
            <label asp-for="Description" class="form-label"></label>
            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <!-- Kategoria -->
        <div class="mb-3">
            <label asp-for="ExerciseCategoryId" class="form-label">Kategoria</label>

            <select asp-for="ExerciseCategoryId" class="form-select">

                <option value="">-- wybierz kategorię --</option>

                @foreach (var category in ViewBag.Categories)
                {
                    <option value="@category.Id"
                            selected="@(category.Id == Model.ExerciseCategoryId)">
                        @category.Name
                    </option>
                }

            </select>

            <span asp-validation-for="ExerciseCategoryId" class="text-danger"></span>
        </div>

        <!-- Grupa mięśniowa -->
        <div class="mb-3">
            <label asp-for="MuscleGroup" class="form-label"></label>
            <input asp-for="MuscleGroup" class="form-control" />
            <span asp-validation-for="MuscleGroup" class="text-danger"></span>
        </div>

        <!-- Trudność -->
        <div class="mb-3">
            <label asp-for="Difficulty" class="form-label"></label>

            <select asp-for="Difficulty" class="form-select">
                <option value="Easy">Łatwe</option>
                <option value="Medium">Średnie</option>
                <option value="Hard">Trudne</option>
            </select>

            <span asp-validation-for="Difficulty" class="text-danger"></span>
        </div>

        <!-- Przyciski -->
        <button type="submit" class="btn btn-warning">
            Zapisz zmiany
        </button>

        <a asp-action="Index" class="btn btn-secondary">
            Anuluj
        </a>

    </form>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}