@model List<ProgressEntry>

@{
    ViewData["Title"] = "Historia Postępu";
    int? exerciseId = (int?)ViewBag.ExerciseId;
    string? exerciseName = ViewBag.ExerciseName;
}

<div class="container mt-4">
    <div class="row mb-4 align-items-center">
        <div class="col-md-8">
            <h2><i class="bi bi-graph-up"></i> Historia Postępu</h2>
            @if (exerciseId.HasValue)
            {
                <p class="text-muted">Ćwiczenie: <strong>@exerciseName</strong></p>
            }
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="LogWorkout" class="btn btn-success">
                <i class="bi bi-check-circle"></i> Zaloguj Trening
            </a>
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus"></i> Nowy Wpis
            </a>
        </div>
    </div>

    @if (Model.Count == 0)
    {
        <div class="alert alert-info">
            Brak wpisów postępu. <a asp-action="Create">Dodaj nowy wpis</a> aby rozpocząć śledzenie postępów!
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Data</th>
                        <th>Ćwiczenie</th>
                        <th>Serie</th>
                        <th>Powtórzenia</th>
                        <th>Waga (kg)</th>
                        <th>Status</th>
                        <th>Akcje</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var entry in Model.OrderByDescending(e => e.Date))
                    {
                        <tr>
                            <td>
                                <small>@entry.Date.ToString("dd.MM.yyyy")</small>
                            </td>
                            <td>
                                <strong>@entry.Exercise?.Name</strong>
                                <br />
                                <small class="text-muted">@entry.Exercise?.ExerciseCategory?.Name</small>
                            </td>
                            <td>@entry.CompletedSets</td>
                            <td>@entry.CompletedReps</td>
                            <td>
                                @if (entry.ActualWeight > 0)
                                {
                                    <span>@entry.ActualWeight</span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                @if (entry.IsCompleted)
                                {
                                    <span class="badge bg-success"><i class="bi bi-check"></i> Ukończone</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Niezukończone</span>
                                }
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@entry.Id" class="btn btn-sm btn-info" title="Szczegóły">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@entry.Id" class="btn btn-sm btn-warning" title="Edytuj">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form method="post" asp-action="Delete" style="display: inline;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@entry.Id" />
                                    <button type="submit" class="btn btn-sm btn-danger" title="Usuń" onclick="return confirm('Czy na pewno?')">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    @if (exerciseId.HasValue)
    {
        <div class="mt-3">
            <a asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Wyczyść Filtr
            </a>
        </div>
    }
</div>
