@model Workout

@{
    ViewData["Title"] = "Nowy Trening";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-body p-4">
                    <h2 class="card-title mb-4">
                        <i class="bi bi-plus-circle"></i> Stwórz Nowy Trening
                    </h2>

                    <form method="post" asp-action="Create">
                        @Html.AntiForgeryToken()

                        <!-- Name -->
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label"></label>
                            <input asp-for="Name" class="form-control" placeholder="np. Trening na klatkę" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <!-- Description -->
                        <div class="mb-3">
                            <label asp-for="Description" class="form-label"></label>
                            <textarea asp-for="Description" class="form-control" rows="4" placeholder="Opis treningu (opcjonalne)"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <!-- Buttons -->
                        <div class="mb-3">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle"></i> Stwórz Trening
                            </button>
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="bi bi-x-circle"></i> Anuluj
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
