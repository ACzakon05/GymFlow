@model List<GymFlow.Models.User>

@{
    ViewData["Title"] = "Zarządzaj Użytkownikami";
    string? searchTerm = ViewBag.SearchTerm;
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2><i class="bi bi-people"></i> Zarządzaj Użytkownikami</h2>
        </div>
        <div class="col-md-4">
            <a asp-action="Dashboard" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Wróć
            </a>
        </div>
    </div>

    <!-- Wyszukiwanie -->
    <div class="card mb-4">
        <div class="card-body">
            <form method="get" asp-action="Index" class="row g-2">
                <div class="col-md-8">
                    <input type="text" name="searchTerm" class="form-control" placeholder="Wyszukaj po nazwie użytkownika lub emailu..." value="@searchTerm" />
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-search"></i> Szukaj
                    </button>
                </div>
                <div class="col-md-2">
                    <a asp-action="Index" class="btn btn-secondary w-100">
                        <i class="bi bi-arrow-clockwise"></i> Resetuj
                    </a>
                </div>
            </form>
        </div>
    </div>

    @if (Model.Count == 0)
    {
        <div class="alert alert-info">
            Brak użytkowników spełniających kryteria wyszukiwania.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Nazwa</th>
                        <th>Email</th>
                        <th>Imię i Nazwisko</th>
                        <th>Rola</th>
                        <th>Status</th>
                        <th>Dołączył</th>
                        <th>Akcje</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td><strong>@user.Username</strong></td>
                            <td>@user.Email</td>
                            <td>@(user.FirstName != null ? $"{user.FirstName} {user.LastName}" : "-")</td>
                            <td>
                                @if (user.Role == GymFlow.Models.UserRole.Admin)
                                {
                                    <span class="badge bg-danger"><i class="bi bi-shield-lock"></i> Admin</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Użytkownik</span>
                                }
                            </td>
                            <td>
                                @if (user.IsActive)
                                {
                                    <span class="badge bg-success"><i class="bi bi-check"></i> Aktywny</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning">Nieaktywny</span>
                                }
                            </td>
                            <td><small>@user.CreatedAt.ToString("dd.MM.yyyy")</small></td>
                            <td>
                                <a asp-action="UserDetails" asp-route-id="@user.Id" class="btn btn-sm btn-info" title="Szczegóły">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="EditUser" asp-route-id="@user.Id" class="btn btn-sm btn-warning" title="Edytuj">
                                    <i class="bi bi-pencil"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
