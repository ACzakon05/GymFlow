@model GymFlow.Models.User

@{
    ViewData["Title"] = "Szczegóły Użytkownika";
    int currentUserId = int.Parse(User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "0");
    bool isCurrentUser = currentUserId == Model.Id;
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2><i class="bi bi-person"></i> @Model.Username</h2>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Wróć
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card mb-3">
                <div class="card-header bg-light">
                    Informacje o Koncie
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label text-muted">Nazwa Użytkownika</label>
                            <p><strong>@Model.Username</strong></p>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-muted">Email</label>
                            <p><strong>@Model.Email</strong></p>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label text-muted">Imię</label>
                            <p>@(Model.FirstName ?? "-")</p>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-muted">Nazwisko</label>
                            <p>@(Model.LastName ?? "-")</p>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label text-muted">Rola</label>
                            <p>
                                @if (Model.Role == GymFlow.Models.UserRole.Admin)
                                {
                                    <span class="badge bg-danger" style="font-size: 0.95rem;"><i class="bi bi-shield-lock"></i> Administrator</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary" style="font-size: 0.95rem;">Użytkownik</span>
                                }
                            </p>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label text-muted">Status</label>
                            <p>
                                @if (Model.IsActive)
                                {
                                    <span class="badge bg-success" style="font-size: 0.95rem;"><i class="bi bi-check"></i> Aktywny</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning" style="font-size: 0.95rem;">Nieaktywny</span>
                                }
                            </p>
                        </div>
                    </div>

                    <hr />

                    <div class="row">
                        <div class="col-md-6">
                            <label class="form-label text-muted">Dołączył</label>
                            <p>@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-header bg-light">
                    Akcje
                </div>
                <div class="card-body d-flex flex-column gap-2">
                    <a asp-action="EditUser" asp-route-id="@Model.Id" class="btn btn-warning">
                        <i class="bi bi-pencil"></i> Edytuj
                    </a>

                    <form method="post" asp-action="ResetPassword">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-info w-100" onclick="return confirm('Resetować hasło na Password123?')">
                            <i class="bi bi-key"></i> Resetuj Hasło
                        </button>
                    </form>

                    <form method="post" asp-action="ToggleActive">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-warning w-100" 
                                @if (isCurrentUser) { <text>disabled</text> }
                                onclick="return confirm('@(Model.IsActive ? "Deaktywować" : "Aktywować") to konto?')">
                            <i class="bi bi-toggle-@(Model.IsActive ? "on" : "off")"></i> 
                            @(Model.IsActive ? "Deaktywuj" : "Aktywuj")
                        </button>
                    </form>

                    <form method="post" asp-action="DeleteUser">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-danger w-100" 
                                @if (isCurrentUser) { <text>disabled</text> }
                                onclick="return confirm('Czy na pewno usunąć tego użytkownika? Akcja jest nieodwracalna!')">
                            <i class="bi bi-trash"></i> Usuń Użytkownika
                        </button>
                    </form>

                    @if (isCurrentUser)
                    {
                        <div class="alert alert-info small">
                            <i class="bi bi-info-circle"></i> Nie możesz zmienić statusu ani usunąć swojego własnego konta!
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
