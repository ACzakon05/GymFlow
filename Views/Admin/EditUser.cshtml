@model GymFlow.Controllers.EditUserViewModel

@{
    ViewData["Title"] = "Edytuj Użytkownika";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2><i class="bi bi-pencil-square"></i> Edytuj Użytkownika</h2>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <form method="post" asp-action="EditUser">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                <input type="hidden" asp-for="Id" />

                <div class="card mb-3">
                    <div class="card-header bg-light">
                        Informacje Podstawowe
                    </div>
                    <div class="card-body">
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="FirstName" class="form-label">Imię</label>
                                <input asp-for="FirstName" class="form-control" />
                                <span asp-validation-for="FirstName" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="LastName" class="form-label">Nazwisko</label>
                                <input asp-for="LastName" class="form-control" />
                                <span asp-validation-for="LastName" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label">Email<span class="text-danger">*</span></label>
                            <input asp-for="Email" type="email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                    </div>
                </div>

                <div class="card mb-3">
                    <div class="card-header bg-light">
                        Uprawnienia i Status
                    </div>
                    <div class="card-body">
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="Role" class="form-label">Rola<span class="text-danger">*</span></label>
                                <select asp-for="Role" class="form-select">
                                    <option value="@GymFlow.Models.UserRole.User">Użytkownik</option>
                                    <option value="@GymFlow.Models.UserRole.Admin">Administrator</option>
                                </select>
                                <span asp-validation-for="Role" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">Status</label>
                                <div class="form-check form-switch">
                                    <input asp-for="IsActive" type="checkbox" class="form-check-input" id="isActiveSwitch" />
                                    <label class="form-check-label" for="isActiveSwitch">
                                        Konto aktywne
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-warning">
                        <i class="bi bi-check"></i> Zapisz Zmiany
                    </button>
                    <a asp-action="UserDetails" asp-route-id="@Model.Id" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Anuluj
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
