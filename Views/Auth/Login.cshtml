@using GymFlow.Controllers
@model LoginViewModel

@{
    ViewData["Title"] = "Logowanie - GymFlow";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-lg">
                <div class="card-body p-4">
                    <h2 class="card-title text-center mb-4">
                        <i class="bi bi-door-open"></i> Logowanie
                    </h2>

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger" role="alert">
                            <i class="bi bi-exclamation-triangle"></i>
                            @foreach (var modelState in ViewData.ModelState.Values)
                            {
                                @foreach (var error in modelState.Errors)
                                {
                                    <div>@error.ErrorMessage</div>
                                }
                            }
                        </div>
                    }

                    <form method="post" asp-action="Login" asp-controller="Auth">
                        @Html.AntiForgeryToken()

                        <!-- Username or Email -->
                        <div class="mb-3">
                            <label asp-for="UsernameOrEmail" class="form-label"></label>
                            <input asp-for="UsernameOrEmail" class="form-control" 
                                   placeholder="Nazwa użytkownika lub email" 
                                   autofocus />
                            <span asp-validation-for="UsernameOrEmail" class="invalid-feedback"></span>
                        </div>

                        <!-- Password -->
                        <div class="mb-3">
                            <label asp-for="Password" class="form-label"></label>
                            <input asp-for="Password" class="form-control" 
                                   placeholder="Wpisz hasło" />
                            <span asp-validation-for="Password" class="invalid-feedback"></span>
                        </div>

                        <!-- Remember Me -->
                        <div class="mb-3 form-check">
                            <input asp-for="RememberMe" class="form-check-input" />
                            <label asp-for="RememberMe" class="form-check-label">
                                Zapamiętaj mnie na 30 dni
                            </label>
                        </div>

                        <!-- Submit Button -->
                        <button type="submit" class="btn btn-primary w-100 mb-3">
                            <i class="bi bi-box-arrow-in-right"></i> Zaloguj się
                        </button>
                    </form>

                    <!-- Link do rejestracji -->
                    <div class="text-center">
                        <p class="text-muted">Nie masz jeszcze konta? 
                            <a asp-action="Register" asp-controller="Auth" class="text-primary fw-bold">
                                Zarejestruj się
                            </a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
